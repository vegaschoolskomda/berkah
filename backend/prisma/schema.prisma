// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]

  @@map("roles")
}

model Branch {
  id        Int       @id @default(autoincrement())
  name      String
  address   String?
  latitude  Decimal?
  longitude Decimal?
  omset     Decimal?  @default(0) // Omset bulanan (Rp)
  margin    Decimal?  @default(0) // Margin (%)
  createdAt DateTime? @default(now()) @map("created_at")

  @@map("branches")
}

model Competitor {
  id        Int      @id @default(autoincrement())
  name      String
  type      String? // e.g., "Digital Printing", "Sablon"
  address   String?
  latitude  Decimal
  longitude Decimal
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("competitors")
}

model User {
  id           Int       @id @default(autoincrement())
  name         String?
  email        String    @unique
  phone        String?
  passwordHash String    @map("password_hash")
  roleId       Int?      @map("role_id")
  createdAt    DateTime? @default(now()) @map("created_at")
  updatedAt    DateTime? @default(now()) @map("updated_at")

  role      Role?      @relation(fields: [roleId], references: [id])
  cashflows Cashflow[]
  cashflowRequests    CashflowChangeRequest[]    @relation("CashflowRequests")
  cashflowReviews     CashflowChangeRequest[]    @relation("CashflowReviews")
  editRequests        TransactionEditRequest[]   @relation("EditRequests")
  editReviews         TransactionEditRequest[]   @relation("EditReviews")
  uploadedDocuments   DocumentFile[]

  @@map("users")
}

model Category {
  id             Int                  @id @default(autoincrement())
  name           String               @unique
  products       Product[]
  opnameSessions StockOpnameSession[]
  createdAt      DateTime?            @default(now()) @map("created_at")
  updatedAt      DateTime?            @default(now()) @updatedAt @map("updated_at")

  @@map("categories")
}

model DocumentCategory {
  id        Int            @id @default(autoincrement())
  name      String         @unique
  documents DocumentFile[]
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @default(now()) @updatedAt @map("updated_at")

  @@map("document_categories")
}

model DocumentFile {
  id           Int              @id @default(autoincrement())
  name         String
  originalName String           @map("original_name")
  storedName   String           @map("stored_name")
  mimeType     String           @map("mime_type")
  extension    String
  sizeBytes    Int              @map("size_bytes")
  fileUrl      String           @map("file_url")
  categoryId   Int              @map("category_id")
  uploadedById Int              @map("uploaded_by_id")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @default(now()) @updatedAt @map("updated_at")

  category   DocumentCategory @relation(fields: [categoryId], references: [id])
  uploadedBy User             @relation(fields: [uploadedById], references: [id])

  @@map("document_files")
}

model Unit {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  products  Product[]
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @default(now()) @updatedAt @map("updated_at")

  @@map("units")
}

model Product {
  id                 Int         @id @default(autoincrement())
  name               String
  description        String?
  categoryId         Int         @map("category_id")
  unitId             Int         @map("unit_id")
  imageUrl           String?     @map("image_url")
  imageUrls          String?     @map("image_urls")
  pricingMode        PricingMode @default(UNIT) @map("pricing_mode")
  productType        ProductType @default(SELLABLE) @map("product_type")
  pricePerUnit       Decimal?    @map("price_per_unit")
  requiresProduction Boolean     @default(false) @map("requires_production")
  hasAssemblyStage   Boolean     @default(false) @map("has_assembly_stage")
  trackStock         Boolean     @default(true) @map("track_stock")
  createdAt          DateTime?   @default(now()) @map("created_at")
  updatedAt          DateTime?   @default(now()) @updatedAt @map("updated_at")

  category      Category         @relation(fields: [categoryId], references: [id])
  unit          Unit             @relation(fields: [unitId], references: [id])
  variants      ProductVariant[]
  ingredients   Ingredient[]
  hppWorksheets HppWorksheet[]

  @@map("products")
}

model ProductVariant {
  id                      Int       @id @default(autoincrement())
  productId               Int       @map("product_id")
  sku                     String    @unique
  variantName             String?   @map("variant_name")
  price                   Decimal
  hpp                     Decimal   @default(0)
  stock                   Int       @default(0)
  size                    String?
  color                   String?
  variantImageUrl         String?   @map("variant_image_url")
  isRollMaterial          Boolean   @default(false) @map("is_roll_material")
  rollPhysicalWidth       Decimal?  @map("roll_physical_width")
  rollEffectivePrintWidth Decimal?  @map("roll_effective_print_width")
  createdAt               DateTime? @default(now()) @map("created_at")
  updatedAt               DateTime? @default(now()) @updatedAt @map("updated_at")

  product                 Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  batches                 Batch[]
  movements               StockMovement[]
  transactionItems        TransactionItem[]
  hppVariableCosts        HppVariableCost[]
  ingredientsAsRaw        Ingredient[]        @relation("RawMaterial")
  opnameItems             StockOpnameItem[]
  rollJobs                ProductionJob[]     @relation("RollUsedInJob")
  batchRolls              ProductionBatch[]   @relation("RollUsedInBatch")
  supplierItems           SupplierItem[]
  priceTiers              VariantPriceTier[]
  variantIngredients      VariantIngredient[] @relation("VariantBOM")
  variantIngredientsAsRaw VariantIngredient[] @relation("VariantRawMaterial")
  hppWorksheets           HppWorksheet[]
  purchaseItems           StockPurchaseItem[]

  @@map("product_variants")
}

model Ingredient {
  id                   Int     @id @default(autoincrement())
  productId            Int     @map("product_id")
  name                 String
  quantity             Decimal
  unit                 String
  price                Decimal @default(0)
  subtotal             Decimal @default(0)
  rawMaterialVariantId Int?    @map("raw_material_variant_id")

  product            Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  rawMaterialVariant ProductVariant? @relation("RawMaterial", fields: [rawMaterialVariantId], references: [id], onDelete: SetNull)

  @@map("ingredients")
}

model Batch {
  id               Int       @id @default(autoincrement())
  productVariantId Int       @map("product_variant_id")
  batchNumber      String    @unique @map("batch_number")
  expirationDate   DateTime? @map("expiration_date")
  stock            Int       @default(0)
  createdAt        DateTime? @default(now()) @map("created_at")
  updatedAt        DateTime? @default(now()) @updatedAt @map("updated_at")

  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@map("batches")
}

enum MovementType {
  IN
  OUT
  ADJUST
}

enum PricingMode {
  UNIT
  AREA_BASED
}

enum ProductType {
  SELLABLE
  RAW_MATERIAL
  SERVICE
}

model StockMovement {
  id               Int          @id @default(autoincrement())
  productVariantId Int          @map("product_variant_id")
  type             MovementType
  quantity         Decimal
  reason           String?
  balanceAfter     Float?       @map("balance_after")
  referenceId      String? @map("reference_id")
  date             DateTime?    @default(now())
  createdAt        DateTime?    @default(now()) @map("created_at")

  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@map("stock_movements")
}

enum PaymentMethod {
  CASH
  QRIS
  BANK_TRANSFER
}

enum TransactionStatus {
  PENDING
  PARTIAL
  PAID
  FAILED
}

model Transaction {
  id                 Int               @id @default(autoincrement())
  invoiceNumber      String            @unique @map("invoice_number")
  totalAmount        Decimal           @map("total_amount")
  tax                Decimal
  discount           Decimal           @default(0)
  shippingCost       Decimal           @default(0) @map("shipping_cost")
  grandTotal         Decimal           @map("grand_total")
  paymentMethod      PaymentMethod     @map("payment_method")
  status             TransactionStatus @default(PENDING)
  customerName       String?           @map("customer_name")
  customerPhone      String?           @map("customer_phone")
  customerAddress    String?           @map("customer_address")
  dueDate            DateTime?         @map("due_date")
  downPayment        Decimal           @default(0) @map("down_payment")
  cashierName        String?           @map("cashier_name")
  employeeName       String?           @map("employee_name")
  bankAccountId      Int?              @map("bank_account_id")
  productionPriority String            @default("NORMAL") @map("production_priority")
  productionDeadline DateTime?         @map("production_deadline")
  productionNotes    String?           @map("production_notes")
  createdAt          DateTime?         @default(now()) @map("created_at")
  updatedAt          DateTime?         @default(now()) @updatedAt @map("updated_at")

  items          TransactionItem[]
  bankAccount    BankAccount?           @relation(fields: [bankAccountId], references: [id])
  productionJobs ProductionJob[]
  editRequests   TransactionEditRequest[]

  @@map("transactions")
}

model TransactionItem {
  id               Int       @id @default(autoincrement())
  transactionId    Int       @map("transaction_id")
  productVariantId Int       @map("product_variant_id")
  quantity         Int
  priceAtTime      Decimal   @map("price_at_time")
  hppAtTime        Decimal   @default(0) @map("hpp_at_time")
  widthCm          Decimal?  @map("width_cm")
  heightCm         Decimal?  @map("height_cm")
  areaCm2          Decimal?  @map("area_cm2")
  note             String?
  createdAt        DateTime? @default(now()) @map("created_at")

  transaction    Transaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])
  productionJob  ProductionJob?

  @@map("transaction_items")
}

enum CashflowType {
  INCOME
  EXPENSE
}

model Cashflow {
  id            Int            @id @default(autoincrement())
  type          CashflowType
  category      String
  amount        Decimal
  note          String?
  userId        Int?           @map("user_id")
  bankAccountId Int?           @map("bank_account_id")
  paymentMethod  PaymentMethod? @map("payment_method")
  platformSource String?        @map("platform_source")
  date           DateTime       @default(now())
  createdAt     DateTime?      @default(now()) @map("created_at")
  updatedAt     DateTime?      @default(now()) @updatedAt @map("updated_at")

  user           User?        @relation(fields: [userId], references: [id])
  bankAccount    BankAccount? @relation(fields: [bankAccountId], references: [id])
  changeRequests CashflowChangeRequest[]

  @@map("cashflows")
}

enum ChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ChangeRequestType {
  EDIT
  DELETE
}

model CashflowChangeRequest {
  id            Int                  @id @default(autoincrement())
  cashflowId    Int                  @map("cashflow_id")
  requesterId   Int                  @map("requester_id")
  type          ChangeRequestType
  status        ChangeRequestStatus  @default(PENDING)
  payload       Json?
  requesterNote String?              @map("requester_note")
  reviewerNote  String?              @map("reviewer_note")
  reviewedBy    Int?                 @map("reviewed_by")
  reviewedAt    DateTime?            @map("reviewed_at")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @default(now()) @updatedAt @map("updated_at")

  cashflow  Cashflow @relation(fields: [cashflowId], references: [id], onDelete: Cascade)
  requester User     @relation("CashflowRequests", fields: [requesterId], references: [id])
  reviewer  User?    @relation("CashflowReviews",  fields: [reviewedBy],  references: [id])

  @@map("cashflow_change_requests")
}

enum EditRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model TransactionEditRequest {
  id            Int               @id @default(autoincrement())
  transactionId Int               @map("transaction_id")
  requestedById Int               @map("requested_by_id")
  reviewedById  Int?              @map("reviewed_by_id")
  status        EditRequestStatus @default(PENDING)
  reason        String
  editData      Json              @map("edit_data")
  reviewNote    String?           @map("review_note")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @default(now()) @updatedAt @map("updated_at")

  transaction  Transaction @relation(fields: [transactionId], references: [id])
  requestedBy  User        @relation("EditRequests", fields: [requestedById], references: [id])
  reviewedBy   User?       @relation("EditReviews",  fields: [reviewedById], references: [id])

  @@map("transaction_edit_requests")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
  ACCEPTED // Quotation accepted
  REJECTED // Quotation rejected
  EXPIRED // Quotation past valid date
}

enum InvoiceType {
  INVOICE
  QUOTATION
}

model Invoice {
  id            Int           @id @default(autoincrement())
  invoiceNumber String        @unique @map("invoice_number")
  type          InvoiceType   @default(INVOICE)
  clientName    String        @map("client_name")
  clientCompany String?       @map("client_company") // Instansi/PT
  clientAddress String?       @map("client_address") // Alamat Lengkap
  clientPhone   String?       @map("client_phone") // No. HP/Telp
  clientEmail   String?       @map("client_email") // Email Perusahaan
  date          DateTime      @default(now())
  dueDate       DateTime?     @map("due_date")
  validUntil    DateTime?     @map("valid_until") // Quotation: masa berlaku penawaran
  status        InvoiceStatus @default(DRAFT)
  subtotal      Decimal       @default(0)
  taxRate       Decimal       @default(0) @map("tax_rate") // % PPN
  taxAmount     Decimal       @default(0) @map("tax_amount") // Rp PPN
  discount      Decimal       @default(0) // Diskon (Rp)
  total         Decimal       @default(0) // Grand Total (Subtotal + PPN - Diskon)
  notes         String? // Syarat & Ketentuan, Garansi, dll
  createdAt     DateTime?     @default(now()) @map("created_at")
  updatedAt     DateTime?     @default(now()) @updatedAt @map("updated_at")

  items InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  id          Int     @id @default(autoincrement())
  invoiceId   Int     @map("invoice_id")
  description String
  unit        String? // Satuan: pcs, m², lembar, set, dll
  quantity    Int
  price       Decimal

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

// ----- HPP Calculator & Recipe Templates ----- //

model HppWorksheet {
  id               Int       @id @default(autoincrement())
  productName      String    @map("product_name")
  targetVolume     Int       @default(1) @map("target_volume")
  targetMargin     Decimal   @default(50) @map("target_margin")
  productVariantId Int?      @map("product_variant_id")
  productId        Int?      @map("product_id")
  appliedAt        DateTime? @map("applied_at")
  createdAt        DateTime? @default(now()) @map("created_at")
  updatedAt        DateTime? @default(now()) @updatedAt @map("updated_at")

  variableCosts  HppVariableCost[]
  fixedCosts     HppFixedCost[]
  productVariant ProductVariant?   @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  product        Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("hpp_worksheets")
}

model HppVariableCost {
  id                 Int      @id @default(autoincrement())
  worksheetId        Int      @map("worksheet_id")
  productVariantId   Int?     @map("product_variant_id") // null if custom material
  customMaterialName String?  @map("custom_material_name")
  customPrice        Decimal? @map("custom_price")
  usageAmount        Decimal  @map("usage_amount")
  usageUnit          String   @map("usage_unit")

  worksheet      HppWorksheet    @relation(fields: [worksheetId], references: [id], onDelete: Cascade)
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id])

  @@map("hpp_variable_costs")
}

model HppFixedCost {
  id          Int     @id @default(autoincrement())
  worksheetId Int     @map("worksheet_id")
  name        String
  amount      Decimal

  worksheet HppWorksheet @relation(fields: [worksheetId], references: [id], onDelete: Cascade)

  @@map("hpp_fixed_costs")
}

model StoreSettings {
  id                    Int       @id @default(autoincrement())
  storeName             String    @map("store_name")
  storeAddress          String?   @map("store_address")
  storePhone            String?   @map("store_phone")
  qrisImageUrl          String?   @map("qris_image_url")
  logoImageUrl          String?   @map("logo_image_url")
  enableAdvancedPricing Boolean   @default(false) @map("enable_advanced_pricing")
  enableTax             Boolean   @default(true) @map("enable_tax")
  taxRate               Decimal   @default(10) @map("tax_rate")
  loginBgImages         String?   @map("login_bg_images")
  loginTaglines         String?   @map("login_taglines")
  operatorPin           String?   @map("operator_pin")
  notifyNewTransaction  Boolean   @default(true) @map("notify_new_transaction")
  notifyLowStock        Boolean   @default(true) @map("notify_low_stock")
  notifyOfflineSync     Boolean   @default(true) @map("notify_offline_sync")
  notifyShiftReminder   Boolean   @default(false) @map("notify_shift_reminder")
  lowStockThreshold     Int       @default(5) @map("low_stock_threshold")
  shiftReminderTime     String?   @map("shift_reminder_time")
  shiftReminderTime2    String?   @map("shift_reminder_time_2")
  notifyGithubCommit     Boolean   @default(true) @map("notify_github_commit")
  discordWebhookUrl      String?   @map("discord_webhook_url")
  githubWebhookSecret    String?   @map("github_webhook_secret")
  createdAt             DateTime? @default(now()) @map("created_at")
  updatedAt             DateTime? @default(now()) @updatedAt @map("updated_at")

  @@map("store_settings")
}

model BankAccount {
  id             Int       @id @default(autoincrement())
  bankName       String    @map("bank_name")
  accountNumber  String    @map("account_number")
  accountOwner   String    @map("account_owner")
  currentBalance Decimal   @default(0) @map("current_balance")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime? @default(now()) @map("created_at")
  updatedAt      DateTime? @default(now()) @updatedAt @map("updated_at")

  transactions Transaction[]
  cashflows    Cashflow[]

  @@map("bank_accounts")
}

model Customer {
  id        Int       @id @default(autoincrement())
  name      String
  phone     String?
  address   String?
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @default(now()) @updatedAt @map("updated_at")

  @@map("customers")
}

// ----- Stock Opname ----- //

enum OpnameStatus {
  ONGOING
  COMPLETED
  CANCELLED
}

model StockOpnameSession {
  id         String       @id @default(uuid())
  notes      String?
  categoryId Int?         @map("category_id")
  status     OpnameStatus @default(ONGOING)
  expiresAt  DateTime     @map("expires_at")
  startDate  DateTime     @default(now()) @map("start_date")
  endDate    DateTime?    @map("end_date")
  createdAt  DateTime?    @default(now()) @map("created_at")
  updatedAt  DateTime?    @default(now()) @updatedAt @map("updated_at")

  category Category?         @relation(fields: [categoryId], references: [id])
  items    StockOpnameItem[]

  @@map("stock_opname_sessions")
}

model StockOpnameItem {
  id               Int      @id @default(autoincrement())
  sessionId        String   @map("session_id")
  operatorName     String   @map("operator_name")
  productVariantId Int      @map("product_variant_id")
  systemStock      Int      @map("system_stock")
  actualStock      Int      @map("actual_stock")
  variance         Int
  isEstimated      Boolean  @default(false) @map("is_estimated")
  estimationNotes  String?  @map("estimation_notes")
  submittedAt      DateTime @default(now()) @map("submitted_at")

  session        StockOpnameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  productVariant ProductVariant     @relation(fields: [productVariantId], references: [id])

  @@map("stock_opname_items")
}

// ----- Produksi / Production Queue ----- //

model ProductionJob {
  id                  Int       @id @default(autoincrement())
  jobNumber           String    @unique @map("job_number")
  transactionId       Int       @map("transaction_id")
  transactionItemId   Int       @unique @map("transaction_item_id")
  status              String    @default("ANTRIAN")
  priority            String    @default("NORMAL")
  deadline            DateTime?
  notes               String?
  operatorNote        String?   @map("operator_note")
  usedWaste           Boolean   @default(false) @map("used_waste")
  rollVariantId       Int?      @map("roll_variant_id")
  rollLengthUsed      Decimal?  @map("roll_length_used")
  batchId             Int?      @map("batch_id")
  startedAt           DateTime? @map("started_at")
  completedAt         DateTime? @map("completed_at")
  assemblyStartedAt   DateTime? @map("assembly_started_at")
  assemblyCompletedAt DateTime? @map("assembly_completed_at")
  assemblyNote        String?   @map("assembly_note")
  pickedUpAt          DateTime? @map("picked_up_at")
  createdAt           DateTime? @default(now()) @map("created_at")
  updatedAt           DateTime? @default(now()) @updatedAt @map("updated_at")

  transaction     Transaction      @relation(fields: [transactionId], references: [id])
  transactionItem TransactionItem  @relation(fields: [transactionItemId], references: [id])
  rollVariant     ProductVariant?  @relation("RollUsedInJob", fields: [rollVariantId], references: [id])
  batch           ProductionBatch? @relation(fields: [batchId], references: [id])

  @@map("production_jobs")
}

model ProductionBatch {
  id             Int       @id @default(autoincrement())
  batchNumber    String    @unique @map("batch_number")
  rollVariantId  Int?      @map("roll_variant_id")
  usedWaste      Boolean   @default(false) @map("used_waste")
  rollLengthUsed Decimal?  @map("roll_length_used")
  status         String    @default("PROSES")
  startedAt      DateTime? @map("started_at")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime? @default(now()) @map("created_at")

  rollVariant ProductVariant? @relation("RollUsedInBatch", fields: [rollVariantId], references: [id])
  jobs        ProductionJob[]

  @@map("production_batches")
}

model Supplier {
  id            Int      @id @default(autoincrement())
  name          String
  contactPerson String?  @map("contact_person")
  phone         String?
  email         String?
  address       String?
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  items          SupplierItem[]
  stockPurchases StockPurchase[]

  @@map("suppliers")
}

model SupplierItem {
  id               Int      @id @default(autoincrement())
  supplierId       Int      @map("supplier_id")
  productVariantId Int      @map("product_variant_id")
  purchasePrice    Decimal  @map("purchase_price")
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  supplier       Supplier       @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@map("supplier_items")
}

// ----- Stock Purchase (Pembelian Bahan Baku) ----- //

model StockPurchase {
  id            Int      @id @default(autoincrement())
  invoiceNumber String? @map("invoice_number")
  supplierId    Int?     @map("supplier_id")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")

  supplier Supplier?          @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  items    StockPurchaseItem[]

  @@map("stock_purchases")
}

model StockPurchaseItem {
  id               Int      @id @default(autoincrement())
  purchaseId       Int      @map("purchase_id")
  productVariantId Int      @map("product_variant_id")
  quantity         Int
  unitPrice        Decimal? @map("unit_price")

  purchase       StockPurchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@map("stock_purchase_items")
}

// ----- Variant Price Tiers (Harga Bertingkat) ----- //

model VariantPriceTier {
  id        Int       @id @default(autoincrement())
  variantId Int       @map("variant_id")
  tierName  String?   @map("tier_name")
  minQty    Int       @map("min_qty")
  maxQty    Int?      @map("max_qty")
  price     Decimal
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @default(now()) @updatedAt @map("updated_at")

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("variant_price_tiers")
}

// ----- Variant Ingredients (BOM per Varian) ----- //

model VariantIngredient {
  id                   Int       @id @default(autoincrement())
  variantId            Int       @map("variant_id")
  name                 String
  quantity             Decimal
  unit                 String
  price                Decimal   @default(0)
  isServiceCost        Boolean   @default(false) @map("is_service_cost")
  rawMaterialVariantId Int?      @map("raw_material_variant_id")
  createdAt            DateTime? @default(now()) @map("created_at")
  updatedAt            DateTime? @default(now()) @updatedAt @map("updated_at")

  variant            ProductVariant  @relation("VariantBOM", fields: [variantId], references: [id], onDelete: Cascade)
  rawMaterialVariant ProductVariant? @relation("VariantRawMaterial", fields: [rawMaterialVariantId], references: [id], onDelete: SetNull)

  @@map("variant_ingredients")
}

model ShiftReport {
  id        Int      @id @default(autoincrement())
  adminName String   @map("admin_name")
  shiftName String   @map("shift_name")
  openedAt  DateTime @map("opened_at")
  closedAt  DateTime @default(now()) @map("closed_at")

  // Cash Information
  expectedCash   Decimal @map("expected_cash")
  actualCash     Decimal @map("actual_cash")
  cashDifference Decimal @map("cash_difference")

  // QRIS Information
  expectedQris   Decimal @map("expected_qris")
  actualQris     Decimal @map("actual_qris")
  qrisDifference Decimal @map("qris_difference")

  // Transfer Information
  expectedTransfer   Decimal @map("expected_transfer")
  actualTransfer     Decimal @map("actual_transfer")
  transferDifference Decimal @map("transfer_difference")

  // Detailed breakdowns for WA report
  expectedBankBalances Json? @map("expected_bank_balances")
  actualBankBalances   Json? @map("actual_bank_balances") // Saldo Laporan mBanking
  realBankBalances     Json? @map("real_bank_balances") // Saldo Real di Bank
  shiftExpenses        Json? @map("shift_expenses")
  structuredExpenses   Json? @map("structured_expenses") // Pengeluaran terstruktur per metode
  kasbon               Json? @map("kasbon")               // [{name: string, amount: number}]
  setorKas             Json? @map("setor_kas")            // [{bankName: string, amount: number}]
  tarikTunai           Json? @map("tarik_tunai")          // [{bankName: string, amount: number}]
  tukarTransferKeCash  Decimal @default(0) @map("tukar_transfer_ke_cash") // Konversi transfer masuk menjadi kas fisik
  additionalIncomes    Json? @map("additional_incomes")   // [{bankName: string, amount: number, description: string}]

  expensesTotal Decimal   @map("expenses_total")
  notes         String?
  proofImages   Json?     @map("proof_images") // Store array of uploaded image paths
  createdAt     DateTime? @default(now()) @map("created_at")

  @@map("shift_reports")
}
