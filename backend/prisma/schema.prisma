// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(20)
  users User[]

  @@map("roles")
}

model Branch {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(100)
  address   String?   @db.Text
  latitude  Decimal?  @db.Decimal(9, 6)
  longitude Decimal?  @db.Decimal(9, 6)
  omset     Decimal?  @default(0) @db.Decimal(15, 2) // Omset bulanan (Rp)
  margin    Decimal?  @default(0) @db.Decimal(5, 2) // Margin (%)
  createdAt DateTime? @default(now()) @map("created_at")

  @@map("branches")
}

model Competitor {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(200)
  type      String?  @db.VarChar(100) // e.g., "Digital Printing", "Sablon"
  address   String?  @db.Text
  latitude  Decimal  @db.Decimal(9, 6)
  longitude Decimal  @db.Decimal(9, 6)
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("competitors")
}

model User {
  id           Int       @id @default(autoincrement())
  name         String?   @db.VarChar(100)
  email        String    @unique @db.VarChar(100)
  phone        String?   @db.VarChar(50)
  passwordHash String    @map("password_hash") @db.VarChar(200)
  roleId       Int?      @map("role_id")
  createdAt    DateTime? @default(now()) @map("created_at")
  updatedAt    DateTime? @default(now()) @map("updated_at")

  role      Role?      @relation(fields: [roleId], references: [id])
  cashflows Cashflow[]

  @@map("users")
}

model Category {
  id             Int                  @id @default(autoincrement())
  name           String               @unique @db.VarChar(100)
  products       Product[]
  opnameSessions StockOpnameSession[]
  createdAt      DateTime?            @default(now()) @map("created_at")
  updatedAt      DateTime?            @default(now()) @updatedAt @map("updated_at")

  @@map("categories")
}

model Unit {
  id        Int       @id @default(autoincrement())
  name      String    @unique @db.VarChar(50)
  products  Product[]
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @default(now()) @updatedAt @map("updated_at")

  @@map("units")
}

model Product {
  id                 Int         @id @default(autoincrement())
  name               String      @db.VarChar(200)
  description        String?     @db.Text
  categoryId         Int         @map("category_id")
  unitId             Int         @map("unit_id")
  imageUrl           String?     @map("image_url") @db.Text
  imageUrls          String?     @map("image_urls") @db.Text
  pricingMode        PricingMode @default(UNIT) @map("pricing_mode")
  productType        ProductType @default(SELLABLE) @map("product_type")
  pricePerUnit       Decimal?    @map("price_per_unit") @db.Decimal(15, 2)
  requiresProduction Boolean     @default(false) @map("requires_production")
  hasAssemblyStage   Boolean     @default(false) @map("has_assembly_stage")
  trackStock         Boolean     @default(true) @map("track_stock")
  createdAt          DateTime?   @default(now()) @map("created_at")
  updatedAt          DateTime?   @default(now()) @updatedAt @map("updated_at")

  category      Category         @relation(fields: [categoryId], references: [id])
  unit          Unit             @relation(fields: [unitId], references: [id])
  variants      ProductVariant[]
  ingredients   Ingredient[]
  hppWorksheets HppWorksheet[]

  @@map("products")
}

model ProductVariant {
  id                      Int       @id @default(autoincrement())
  productId               Int       @map("product_id")
  sku                     String    @unique @db.VarChar(100)
  variantName             String?   @map("variant_name") @db.VarChar(100)
  price                   Decimal   @db.Decimal(15, 2)
  hpp                     Decimal   @default(0) @db.Decimal(15, 2)
  stock                   Int       @default(0)
  size                    String?   @db.VarChar(50)
  color                   String?   @db.VarChar(50)
  variantImageUrl         String?   @map("variant_image_url") @db.Text
  isRollMaterial          Boolean   @default(false) @map("is_roll_material")
  rollPhysicalWidth       Decimal?  @map("roll_physical_width") @db.Decimal(10, 2)
  rollEffectivePrintWidth Decimal?  @map("roll_effective_print_width") @db.Decimal(10, 2)
  createdAt               DateTime? @default(now()) @map("created_at")
  updatedAt               DateTime? @default(now()) @updatedAt @map("updated_at")

  product                 Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  batches                 Batch[]
  movements               StockMovement[]
  transactionItems        TransactionItem[]
  hppVariableCosts        HppVariableCost[]
  ingredientsAsRaw        Ingredient[]        @relation("RawMaterial")
  opnameItems             StockOpnameItem[]
  rollJobs                ProductionJob[]     @relation("RollUsedInJob")
  batchRolls              ProductionBatch[]   @relation("RollUsedInBatch")
  supplierItems           SupplierItem[]
  priceTiers              VariantPriceTier[]
  variantIngredients      VariantIngredient[] @relation("VariantBOM")
  variantIngredientsAsRaw VariantIngredient[] @relation("VariantRawMaterial")
  hppWorksheets           HppWorksheet[]

  @@map("product_variants")
}

model Ingredient {
  id                   Int     @id @default(autoincrement())
  productId            Int     @map("product_id")
  name                 String  @db.VarChar(200)
  quantity             Decimal @db.Decimal(10, 3)
  unit                 String  @db.VarChar(50)
  price                Decimal @default(0) @db.Decimal(15, 2)
  subtotal             Decimal @default(0) @db.Decimal(15, 2)
  rawMaterialVariantId Int?    @map("raw_material_variant_id")

  product            Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  rawMaterialVariant ProductVariant? @relation("RawMaterial", fields: [rawMaterialVariantId], references: [id], onDelete: SetNull)

  @@map("ingredients")
}

model Batch {
  id               Int       @id @default(autoincrement())
  productVariantId Int       @map("product_variant_id")
  batchNumber      String    @unique @map("batch_number") @db.VarChar(100)
  expirationDate   DateTime? @map("expiration_date") @db.Date
  stock            Int       @default(0)
  createdAt        DateTime? @default(now()) @map("created_at")
  updatedAt        DateTime? @default(now()) @updatedAt @map("updated_at")

  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@map("batches")
}

enum MovementType {
  IN
  OUT
  ADJUST
}

enum PricingMode {
  UNIT
  AREA_BASED
}

enum ProductType {
  SELLABLE
  RAW_MATERIAL
  SERVICE
}

model StockMovement {
  id               Int          @id @default(autoincrement())
  productVariantId Int          @map("product_variant_id")
  type             MovementType
  quantity         Int
  reason           String?      @db.VarChar(255)
  date             DateTime?    @default(now())
  createdAt        DateTime?    @default(now()) @map("created_at")

  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@map("stock_movements")
}

enum PaymentMethod {
  CASH
  QRIS
  BANK_TRANSFER
}

enum TransactionStatus {
  PENDING
  PARTIAL
  PAID
  FAILED
}

model Transaction {
  id                 Int               @id @default(autoincrement())
  invoiceNumber      String            @unique @map("invoice_number") @db.VarChar(100)
  totalAmount        Decimal           @map("total_amount") @db.Decimal(15, 2)
  tax                Decimal           @db.Decimal(15, 2)
  discount           Decimal           @default(0) @db.Decimal(15, 2)
  grandTotal         Decimal           @map("grand_total") @db.Decimal(15, 2)
  paymentMethod      PaymentMethod     @map("payment_method")
  status             TransactionStatus @default(PENDING)
  customerName       String?           @map("customer_name") @db.VarChar(200)
  customerPhone      String?           @map("customer_phone") @db.VarChar(50)
  customerAddress    String?           @map("customer_address") @db.Text
  dueDate            DateTime?         @map("due_date")
  downPayment        Decimal           @default(0) @map("down_payment") @db.Decimal(15, 2)
  cashierName        String?           @map("cashier_name") @db.VarChar(100)
  employeeName       String?           @map("employee_name") @db.VarChar(100)
  bankAccountId      Int?              @map("bank_account_id")
  productionPriority String            @default("NORMAL") @map("production_priority") @db.VarChar(20)
  productionDeadline DateTime?         @map("production_deadline")
  productionNotes    String?           @map("production_notes") @db.Text
  createdAt          DateTime?         @default(now()) @map("created_at")
  updatedAt          DateTime?         @default(now()) @updatedAt @map("updated_at")

  items          TransactionItem[]
  bankAccount    BankAccount?      @relation(fields: [bankAccountId], references: [id])
  productionJobs ProductionJob[]

  @@map("transactions")
}

model TransactionItem {
  id               Int       @id @default(autoincrement())
  transactionId    Int       @map("transaction_id")
  productVariantId Int       @map("product_variant_id")
  quantity         Int
  priceAtTime      Decimal   @map("price_at_time") @db.Decimal(15, 2)
  hppAtTime        Decimal   @default(0) @map("hpp_at_time") @db.Decimal(15, 2)
  widthCm          Decimal?  @map("width_cm") @db.Decimal(10, 2)
  heightCm         Decimal?  @map("height_cm") @db.Decimal(10, 2)
  areaCm2          Decimal?  @map("area_cm2") @db.Decimal(15, 4)
  note             String?   @db.Text
  createdAt        DateTime? @default(now()) @map("created_at")

  transaction    Transaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])
  productionJob  ProductionJob?

  @@map("transaction_items")
}

enum CashflowType {
  INCOME
  EXPENSE
}

model Cashflow {
  id            Int            @id @default(autoincrement())
  type          CashflowType
  category      String         @db.VarChar(100)
  amount        Decimal        @db.Decimal(15, 2)
  note          String?        @db.Text
  userId        Int?           @map("user_id")
  bankAccountId Int?           @map("bank_account_id")
  paymentMethod  PaymentMethod? @map("payment_method")
  platformSource String?        @map("platform_source") @db.VarChar(100)
  date           DateTime       @default(now())
  createdAt     DateTime?      @default(now()) @map("created_at")
  updatedAt     DateTime?      @default(now()) @updatedAt @map("updated_at")

  user        User?        @relation(fields: [userId], references: [id])
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id])

  @@map("cashflows")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
  ACCEPTED // Quotation accepted
  REJECTED // Quotation rejected
  EXPIRED // Quotation past valid date
}

enum InvoiceType {
  INVOICE
  QUOTATION
}

model Invoice {
  id            Int           @id @default(autoincrement())
  invoiceNumber String        @unique @map("invoice_number") @db.VarChar(100)
  type          InvoiceType   @default(INVOICE)
  clientName    String        @map("client_name") @db.VarChar(200)
  clientCompany String?       @map("client_company") @db.VarChar(200) // Instansi/PT
  clientAddress String?       @map("client_address") @db.Text // Alamat Lengkap
  clientPhone   String?       @map("client_phone") @db.VarChar(50) // No. HP/Telp
  clientEmail   String?       @map("client_email") @db.VarChar(150) // Email Perusahaan
  date          DateTime      @default(now())
  dueDate       DateTime?     @map("due_date")
  validUntil    DateTime?     @map("valid_until") // Quotation: masa berlaku penawaran
  status        InvoiceStatus @default(DRAFT)
  subtotal      Decimal       @default(0) @db.Decimal(15, 2)
  taxRate       Decimal       @default(0) @map("tax_rate") @db.Decimal(5, 2) // % PPN
  taxAmount     Decimal       @default(0) @map("tax_amount") @db.Decimal(15, 2) // Rp PPN
  discount      Decimal       @default(0) @db.Decimal(15, 2) // Diskon (Rp)
  total         Decimal       @default(0) @db.Decimal(15, 2) // Grand Total (Subtotal + PPN - Diskon)
  notes         String?       @db.Text // Syarat & Ketentuan, Garansi, dll
  createdAt     DateTime?     @default(now()) @map("created_at")
  updatedAt     DateTime?     @default(now()) @updatedAt @map("updated_at")

  items InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  id          Int     @id @default(autoincrement())
  invoiceId   Int     @map("invoice_id")
  description String  @db.VarChar(255)
  unit        String? @db.VarChar(50) // Satuan: pcs, m², lembar, set, dll
  quantity    Int
  price       Decimal @db.Decimal(15, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

// ----- HPP Calculator & Recipe Templates ----- //

model HppWorksheet {
  id               Int       @id @default(autoincrement())
  productName      String    @map("product_name") @db.VarChar(200)
  targetVolume     Int       @default(1) @map("target_volume")
  targetMargin     Decimal   @default(50) @map("target_margin") @db.Decimal(10, 2)
  productVariantId Int?      @map("product_variant_id")
  productId        Int?      @map("product_id")
  appliedAt        DateTime? @map("applied_at")
  createdAt        DateTime? @default(now()) @map("created_at")
  updatedAt        DateTime? @default(now()) @updatedAt @map("updated_at")

  variableCosts  HppVariableCost[]
  fixedCosts     HppFixedCost[]
  productVariant ProductVariant?   @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  product        Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("hpp_worksheets")
}

model HppVariableCost {
  id                 Int      @id @default(autoincrement())
  worksheetId        Int      @map("worksheet_id")
  productVariantId   Int?     @map("product_variant_id") // null if custom material
  customMaterialName String?  @map("custom_material_name") @db.VarChar(200)
  customPrice        Decimal? @map("custom_price") @db.Decimal(15, 2)
  usageAmount        Decimal  @map("usage_amount") @db.Decimal(15, 4)
  usageUnit          String   @map("usage_unit") @db.VarChar(50)

  worksheet      HppWorksheet    @relation(fields: [worksheetId], references: [id], onDelete: Cascade)
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id])

  @@map("hpp_variable_costs")
}

model HppFixedCost {
  id          Int     @id @default(autoincrement())
  worksheetId Int     @map("worksheet_id")
  name        String  @db.VarChar(150)
  amount      Decimal @db.Decimal(15, 2)

  worksheet HppWorksheet @relation(fields: [worksheetId], references: [id], onDelete: Cascade)

  @@map("hpp_fixed_costs")
}

model StoreSettings {
  id                    Int       @id @default(autoincrement())
  storeName             String    @map("store_name") @db.VarChar(200)
  storeAddress          String?   @map("store_address") @db.Text
  storePhone            String?   @map("store_phone") @db.VarChar(50)
  qrisImageUrl          String?   @map("qris_image_url") @db.Text
  logoImageUrl          String?   @map("logo_image_url") @db.Text
  enableAdvancedPricing Boolean   @default(false) @map("enable_advanced_pricing")
  enableTax             Boolean   @default(true) @map("enable_tax")
  taxRate               Decimal   @default(10) @map("tax_rate") @db.Decimal(5, 2)
  loginBgImages         String?   @map("login_bg_images") @db.Text
  loginTaglines         String?   @map("login_taglines") @db.Text
  operatorPin           String?   @map("operator_pin") @db.VarChar(10)
  notifyNewTransaction  Boolean   @default(true) @map("notify_new_transaction")
  notifyLowStock        Boolean   @default(true) @map("notify_low_stock")
  notifyOfflineSync     Boolean   @default(true) @map("notify_offline_sync")
  notifyShiftReminder   Boolean   @default(false) @map("notify_shift_reminder")
  lowStockThreshold     Int       @default(5) @map("low_stock_threshold")
  shiftReminderTime     String?   @map("shift_reminder_time") @db.VarChar(5)
  shiftReminderTime2    String?   @map("shift_reminder_time_2") @db.VarChar(5)
  notifyGithubCommit     Boolean   @default(true) @map("notify_github_commit")
  discordWebhookUrl      String?   @map("discord_webhook_url") @db.Text
  githubWebhookSecret    String?   @map("github_webhook_secret") @db.VarChar(200)
  createdAt             DateTime? @default(now()) @map("created_at")
  updatedAt             DateTime? @default(now()) @updatedAt @map("updated_at")

  @@map("store_settings")
}

model BankAccount {
  id             Int       @id @default(autoincrement())
  bankName       String    @map("bank_name") @db.VarChar(100)
  accountNumber  String    @map("account_number") @db.VarChar(100)
  accountOwner   String    @map("account_owner") @db.VarChar(100)
  currentBalance Decimal   @default(0) @map("current_balance") @db.Decimal(15, 2)
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime? @default(now()) @map("created_at")
  updatedAt      DateTime? @default(now()) @updatedAt @map("updated_at")

  transactions Transaction[]
  cashflows    Cashflow[]

  @@map("bank_accounts")
}

model Customer {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(100)
  phone     String?   @db.VarChar(50)
  address   String?   @db.Text
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @default(now()) @updatedAt @map("updated_at")

  @@map("customers")
}

// ----- Stock Opname ----- //

enum OpnameStatus {
  ONGOING
  COMPLETED
  CANCELLED
}

model StockOpnameSession {
  id         String       @id @default(uuid())
  notes      String?      @db.Text
  categoryId Int?         @map("category_id")
  status     OpnameStatus @default(ONGOING)
  expiresAt  DateTime     @map("expires_at")
  startDate  DateTime     @default(now()) @map("start_date")
  endDate    DateTime?    @map("end_date")
  createdAt  DateTime?    @default(now()) @map("created_at")
  updatedAt  DateTime?    @default(now()) @updatedAt @map("updated_at")

  category Category?         @relation(fields: [categoryId], references: [id])
  items    StockOpnameItem[]

  @@map("stock_opname_sessions")
}

model StockOpnameItem {
  id               Int      @id @default(autoincrement())
  sessionId        String   @map("session_id")
  operatorName     String   @map("operator_name") @db.VarChar(100)
  productVariantId Int      @map("product_variant_id")
  systemStock      Int      @map("system_stock")
  actualStock      Int      @map("actual_stock")
  variance         Int
  isEstimated      Boolean  @default(false) @map("is_estimated")
  estimationNotes  String?  @map("estimation_notes") @db.Text
  submittedAt      DateTime @default(now()) @map("submitted_at")

  session        StockOpnameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  productVariant ProductVariant     @relation(fields: [productVariantId], references: [id])

  @@map("stock_opname_items")
}

// ----- Produksi / Production Queue ----- //

model ProductionJob {
  id                  Int       @id @default(autoincrement())
  jobNumber           String    @unique @map("job_number") @db.VarChar(50)
  transactionId       Int       @map("transaction_id")
  transactionItemId   Int       @unique @map("transaction_item_id")
  status              String    @default("ANTRIAN") @db.VarChar(20)
  priority            String    @default("NORMAL") @db.VarChar(20)
  deadline            DateTime?
  notes               String?   @db.Text
  operatorNote        String?   @map("operator_note") @db.Text
  usedWaste           Boolean   @default(false) @map("used_waste")
  rollVariantId       Int?      @map("roll_variant_id")
  rollLengthUsed      Decimal?  @map("roll_length_used") @db.Decimal(10, 2)
  batchId             Int?      @map("batch_id")
  startedAt           DateTime? @map("started_at")
  completedAt         DateTime? @map("completed_at")
  assemblyStartedAt   DateTime? @map("assembly_started_at")
  assemblyCompletedAt DateTime? @map("assembly_completed_at")
  assemblyNote        String?   @map("assembly_note") @db.Text
  pickedUpAt          DateTime? @map("picked_up_at")
  createdAt           DateTime? @default(now()) @map("created_at")
  updatedAt           DateTime? @default(now()) @updatedAt @map("updated_at")

  transaction     Transaction      @relation(fields: [transactionId], references: [id])
  transactionItem TransactionItem  @relation(fields: [transactionItemId], references: [id])
  rollVariant     ProductVariant?  @relation("RollUsedInJob", fields: [rollVariantId], references: [id])
  batch           ProductionBatch? @relation(fields: [batchId], references: [id])

  @@map("production_jobs")
}

model ProductionBatch {
  id             Int       @id @default(autoincrement())
  batchNumber    String    @unique @map("batch_number") @db.VarChar(50)
  rollVariantId  Int?      @map("roll_variant_id")
  usedWaste      Boolean   @default(false) @map("used_waste")
  rollLengthUsed Decimal?  @map("roll_length_used") @db.Decimal(10, 2)
  status         String    @default("PROSES") @db.VarChar(20)
  startedAt      DateTime? @map("started_at")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime? @default(now()) @map("created_at")

  rollVariant ProductVariant? @relation("RollUsedInBatch", fields: [rollVariantId], references: [id])
  jobs        ProductionJob[]

  @@map("production_batches")
}

model Supplier {
  id            Int      @id @default(autoincrement())
  name          String   @db.VarChar(200)
  contactPerson String?  @map("contact_person") @db.VarChar(200)
  phone         String?  @db.VarChar(50)
  email         String?  @db.VarChar(200)
  address       String?  @db.Text
  notes         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  items SupplierItem[]

  @@map("suppliers")
}

model SupplierItem {
  id               Int      @id @default(autoincrement())
  supplierId       Int      @map("supplier_id")
  productVariantId Int      @map("product_variant_id")
  purchasePrice    Decimal  @map("purchase_price") @db.Decimal(15, 2)
  notes            String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  supplier       Supplier       @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@map("supplier_items")
}

// ----- Variant Price Tiers (Harga Bertingkat) ----- //

model VariantPriceTier {
  id        Int       @id @default(autoincrement())
  variantId Int       @map("variant_id")
  tierName  String?   @map("tier_name") @db.VarChar(100)
  minQty    Int       @map("min_qty")
  maxQty    Int?      @map("max_qty")
  price     Decimal   @db.Decimal(15, 2)
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @default(now()) @updatedAt @map("updated_at")

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("variant_price_tiers")
}

// ----- Variant Ingredients (BOM per Varian) ----- //

model VariantIngredient {
  id                   Int       @id @default(autoincrement())
  variantId            Int       @map("variant_id")
  name                 String    @db.VarChar(200)
  quantity             Decimal   @db.Decimal(10, 3)
  unit                 String    @db.VarChar(50)
  price                Decimal   @default(0) @db.Decimal(15, 2)
  isServiceCost        Boolean   @default(false) @map("is_service_cost")
  rawMaterialVariantId Int?      @map("raw_material_variant_id")
  createdAt            DateTime? @default(now()) @map("created_at")
  updatedAt            DateTime? @default(now()) @updatedAt @map("updated_at")

  variant            ProductVariant  @relation("VariantBOM", fields: [variantId], references: [id], onDelete: Cascade)
  rawMaterialVariant ProductVariant? @relation("VariantRawMaterial", fields: [rawMaterialVariantId], references: [id], onDelete: SetNull)

  @@map("variant_ingredients")
}

model ShiftReport {
  id        Int      @id @default(autoincrement())
  adminName String   @map("admin_name") @db.VarChar(100)
  shiftName String   @map("shift_name") @db.VarChar(50)
  openedAt  DateTime @map("opened_at")
  closedAt  DateTime @default(now()) @map("closed_at")

  // Cash Information
  expectedCash   Decimal @map("expected_cash") @db.Decimal(15, 2)
  actualCash     Decimal @map("actual_cash") @db.Decimal(15, 2)
  cashDifference Decimal @map("cash_difference") @db.Decimal(15, 2)

  // QRIS Information
  expectedQris   Decimal @map("expected_qris") @db.Decimal(15, 2)
  actualQris     Decimal @map("actual_qris") @db.Decimal(15, 2)
  qrisDifference Decimal @map("qris_difference") @db.Decimal(15, 2)

  // Transfer Information
  expectedTransfer   Decimal @map("expected_transfer") @db.Decimal(15, 2)
  actualTransfer     Decimal @map("actual_transfer") @db.Decimal(15, 2)
  transferDifference Decimal @map("transfer_difference") @db.Decimal(15, 2)

  // Detailed breakdowns for WA report
  expectedBankBalances Json? @map("expected_bank_balances")
  actualBankBalances   Json? @map("actual_bank_balances") // Saldo Laporan mBanking
  realBankBalances     Json? @map("real_bank_balances") // Saldo Real di Bank
  shiftExpenses        Json? @map("shift_expenses")
  structuredExpenses   Json? @map("structured_expenses") // Pengeluaran terstruktur per metode
  kasbon               Json? @map("kasbon")               // [{name: string, amount: number}]
  setorKas             Json? @map("setor_kas")            // [{bankName: string, amount: number}]
  tarikTunai           Json? @map("tarik_tunai")          // [{bankName: string, amount: number}]
  tukarTransferKeCash  Decimal @default(0) @map("tukar_transfer_ke_cash") @db.Decimal(15, 2) // Konversi transfer masuk menjadi kas fisik
  additionalIncomes    Json? @map("additional_incomes")   // [{bankName: string, amount: number, description: string}]

  expensesTotal Decimal   @map("expenses_total") @db.Decimal(15, 2)
  notes         String?   @db.Text
  proofImages   Json?     @map("proof_images") // Store array of uploaded image paths
  createdAt     DateTime? @default(now()) @map("created_at")

  @@map("shift_reports")
}
